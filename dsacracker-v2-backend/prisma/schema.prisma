generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  lcUsername   String?  // Optional field for LeetCode Sync
  progressData String?  // Stringified JSON representing the Zustand 'data' state
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
